---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="F1 Data" description="Live F1 driver standings, constructor standings, and race results from Turn1Visuals.">

  <div class="page-header">
    <div class="container">
      <p class="section-label">Formula 1</p>
      <h1 class="page-title">F1 Data Hub</h1>
      <p class="page-desc">Live standings and results — always up to date.</p>
    </div>
  </div>

  <div class="container hub-body">

    <!-- Sub-page nav -->
    <nav class="sub-nav">
      <a href="/f1" class="sub-nav-link sub-nav-link--active">Overview</a>
      <a href="/f1/drivers" class="sub-nav-link">Drivers</a>
      <a href="/f1/teams" class="sub-nav-link">Teams</a>
      <a href="/f1/results" class="sub-nav-link">Results</a>
    </nav>

    <div class="hub-grid">

      <!-- Driver Standings -->
      <section class="hub-section">
        <div class="hub-section-header">
          <p class="section-label">Drivers</p>
          <a href="/f1/drivers" class="section-link">Full standings →</a>
        </div>
        <div class="standings-table" id="driverStandings">
          <!-- Skeleton -->
          {Array.from({length: 5}).map(_ => (
            <div class="standings-row skeleton-row">
              <div class="skeleton skeleton-pos"></div>
              <div class="skeleton skeleton-name"></div>
              <div class="skeleton skeleton-pts"></div>
            </div>
          ))}
        </div>
      </section>

      <!-- Constructor Standings -->
      <section class="hub-section">
        <div class="hub-section-header">
          <p class="section-label">Constructors</p>
          <a href="/f1/teams" class="section-link">Full standings →</a>
        </div>
        <div class="standings-table" id="constructorStandings">
          {Array.from({length: 5}).map(_ => (
            <div class="standings-row skeleton-row">
              <div class="skeleton skeleton-pos"></div>
              <div class="skeleton skeleton-name"></div>
              <div class="skeleton skeleton-pts"></div>
            </div>
          ))}
        </div>
      </section>

    </div>

    <!-- Season Calendar -->
    <section class="recent-results-section">
      <div class="hub-section-header">
        <p class="section-label">Season Calendar</p>
        <a href="/f1/results" class="section-link">All results →</a>
      </div>
      <div id="recentResults">
        {Array.from({length: 6}).map(() => (
          <div class="result-card skeleton-card">
            <div class="skeleton skeleton-race-name"></div>
            <div class="skeleton skeleton-race-sub"></div>
          </div>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>

<script>
  const COUNTRY_FLAGS: Record<string, string> = {
    'Australia':            '🇦🇺',
    'Austria':              '🇦🇹',
    'Azerbaijan':           '🇦🇿',
    'Bahrain':              '🇧🇭',
    'Belgium':              '🇧🇪',
    'Brazil':               '🇧🇷',
    'Canada':               '🇨🇦',
    'China':                '🇨🇳',
    'France':               '🇫🇷',
    'Hungary':              '🇭🇺',
    'Italy':                '🇮🇹',
    'Japan':                '🇯🇵',
    'Mexico':               '🇲🇽',
    'Monaco':               '🇲🇨',
    'Netherlands':          '🇳🇱',
    'Qatar':                '🇶🇦',
    'Saudi Arabia':         '🇸🇦',
    'Singapore':            '🇸🇬',
    'Spain':                '🇪🇸',
    'United Arab Emirates': '🇦🇪',
    'United Kingdom':       '🇬🇧',
    'USA':                  '🇺🇸',
    'United States':        '🇺🇸',
  };

  async function loadData() {
    const BASE = 'https://api.jolpi.ca/ergast/f1';

    // Fetch all in parallel
    const [driversRes, constructorsRes, resultsRes] = await Promise.allSettled([
      fetch(`${BASE}/current/driverStandings.json?limit=5`),
      fetch(`${BASE}/current/constructorStandings.json?limit=5`),
      fetch(`${BASE}/current/results.json?limit=3`),
    ]);

    // Driver standings
    const driverEl = document.getElementById('driverStandings');
    if (driverEl && driversRes.status === 'fulfilled' && driversRes.value.ok) {
      const data = await driversRes.value.json();
      const standings = data.MRData?.StandingsTable?.StandingsLists?.[0]?.DriverStandings ?? [];
      driverEl.innerHTML = standings.slice(0, 5).map((s: any) => `
        <div class="standings-row">
          <span class="pos">${s.position}</span>
          <div class="driver-info">
            <span class="driver-name">${s.Driver.givenName} ${s.Driver.familyName}</span>
            <span class="driver-team">${s.Constructors[0]?.name ?? ''}</span>
          </div>
          <span class="points">${s.points} <span class="pts-label">pts</span></span>
        </div>
      `).join('') || '<p class="no-data">No data available</p>';
    } else if (driverEl) {
      driverEl.innerHTML = '<p class="no-data">Could not load standings</p>';
    }

    // Constructor standings
    const constructorEl = document.getElementById('constructorStandings');
    if (constructorEl && constructorsRes.status === 'fulfilled' && constructorsRes.value.ok) {
      const data = await constructorsRes.value.json();
      const standings = data.MRData?.StandingsTable?.StandingsLists?.[0]?.ConstructorStandings ?? [];
      constructorEl.innerHTML = standings.slice(0, 5).map((s: any) => `
        <div class="standings-row">
          <span class="pos">${s.position}</span>
          <div class="driver-info">
            <span class="driver-name">${s.Constructor.name}</span>
            <span class="driver-team">${s.Constructor.nationality}</span>
          </div>
          <span class="points">${s.points} <span class="pts-label">pts</span></span>
        </div>
      `).join('') || '<p class="no-data">No data available</p>';
    } else if (constructorEl) {
      constructorEl.innerHTML = '<p class="no-data">Could not load standings</p>';
    }

    // Season calendar + results
    const resultsEl = document.getElementById('recentResults');
    const [scheduleRes, resultsData] = await Promise.allSettled([
      fetch(`${BASE}/current.json`).then(r => r.json()),
      resultsRes.status === 'fulfilled' && resultsRes.value.ok
        ? resultsRes.value.json()
        : Promise.resolve(null),
    ]);

    if (resultsEl) {
      const schedule = (scheduleRes.status === 'fulfilled'
        ? scheduleRes.value?.MRData?.RaceTable?.Races
        : null) ?? [];
      const resultsMap = new Map<string, any>();
      const resultRaces = (resultsData.status === 'fulfilled' && resultsData.value)
        ? resultsData.value?.MRData?.RaceTable?.Races ?? []
        : [];
      for (const r of resultRaces) resultsMap.set(r.round, r.Results?.[0]);

      if (schedule.length === 0) {
        resultsEl.innerHTML = '<p class="no-data">Schedule not available</p>';
      } else {
        const now = Date.now();
        let nextFound = false;
        resultsEl.innerHTML = schedule.map((race: any) => {
          const raceDate = new Date(race.date);
          const isPast = raceDate.getTime() < now;
          const isNext = !isPast && !nextFound;
          if (isNext) nextFound = true;
          const winner = resultsMap.get(race.round);
          const dateStr = raceDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
          const flag = COUNTRY_FLAGS[race.Circuit.Location.country] ?? '';
          const cardClass = isPast ? ' is-past' : isNext ? ' is-next' : '';
          const bottomHtml = winner
            ? `<div class="rc-winner">
                <span class="rc-winner-label">Winner</span>
                <span class="rc-winner-name">${winner.Driver.familyName}</span>
                <span class="rc-winner-team">${winner.Constructor.name}</span>
              </div>`
            : isNext
              ? `<div class="rc-next-badge">Next Race</div>`
              : '';
          const tag = isPast ? `a href="/f1/results?round=${race.round}"` : 'div';
          const closeTag = isPast ? 'a' : 'div';
          return `
            <${tag} class="result-card${cardClass}">
              <div class="rc-meta">
                <span class="rc-round">R${race.round}</span>
                <span class="rc-date">${dateStr}</span>
              </div>
              <h3 class="rc-name">${flag ? flag + ' ' : ''}${race.raceName.replace('Grand Prix', 'GP')}</h3>
              <p class="rc-location">${race.Circuit.Location.locality} · ${race.Circuit.Location.country}</p>
              ${bottomHtml}
            </${closeTag}>
          `;
        }).join('');
      }
    }
  }

  loadData();
</script>

<style>
  .page-header {
    padding-block: 4rem 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    text-transform: uppercase;
    line-height: 1;
    margin-top: 0.5rem;
  }

  .page-desc { color: var(--color-muted); font-size: 0.95rem; margin-top: 0.5rem; }

  .hub-body { padding-block: 2.5rem 5rem; }

  /* Sub-nav */
  .sub-nav {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .sub-nav-link {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 0.75rem 1.25rem;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .sub-nav-link:hover { color: var(--color-text); }
  .sub-nav-link--active { color: var(--color-text); border-bottom-color: var(--color-accent); }

  /* Hub grid */
  .hub-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .hub-section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .section-link {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    transition: color 0.15s;
  }

  .section-link:hover { color: var(--color-text); }

  /* Standings rows */
  .standings-table { display: flex; flex-direction: column; gap: 2px; }

  .standings-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .pos {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-muted);
    min-width: 1.5rem;
    text-align: center;
  }

  .driver-info { flex: 1; }

  .driver-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
  }

  .driver-team {
    font-size: 0.75rem;
    color: var(--color-muted);
    display: block;
  }

  .points {
    font-family: 'Inter', monospace;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    text-align: right;
  }

  .pts-label {
    font-size: 0.65rem;
    font-weight: 400;
    color: var(--color-muted);
    margin-left: 2px;
  }

  /* Skeleton */
  .skeleton-row { gap: 1rem; padding: 0.75rem 1rem; background: var(--color-surface); border: 1px solid var(--color-border); display: flex; align-items: center; }
  .skeleton-pos  { width: 1.5rem; height: 1.4rem; }
  .skeleton-name { flex: 1; height: 1.4rem; }
  .skeleton-pts  { width: 3.5rem; height: 1.4rem; }

  /* Season calendar */
  .recent-results-section { margin-top: 1rem; }

  #recentResults {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  :global(.result-card) {
    background: var(--color-surface);
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    min-height: 130px;
  }

  :global(a.result-card) { text-decoration: none; color: inherit; }
  :global(a.result-card:hover) { border-color: var(--color-muted); opacity: 0.75; }
  :global(.result-card.is-past) { opacity: 0.5; }

  :global(.result-card.is-next) {
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface));
    outline: 1px solid var(--color-accent);
    outline-offset: -1px;
    opacity: 1;
  }

  .skeleton-card { height: 130px; }
  .skeleton-race-name { height: 1.1rem; margin-bottom: 0.5rem; }
  .skeleton-race-sub  { height: 0.8rem; width: 60%; }

  :global(.rc-meta) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
  }

  :global(.rc-round) {
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  :global(.rc-date) {
    font-size: 0.7rem;
    color: var(--color-muted);
  }

  :global(.rc-name) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.88rem;
    text-transform: uppercase;
    line-height: 1.25;
    margin-bottom: 0.2rem;
  }

  :global(.rc-location) {
    font-size: 0.74rem;
    color: var(--color-muted);
    flex: 1;
  }

  :global(.rc-winner) {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding-top: 0.65rem;
    border-top: 1px solid var(--color-border);
    margin-top: 0.65rem;
  }

  :global(.rc-winner-label) {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  :global(.rc-winner-name) {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  :global(.rc-winner-team) {
    font-size: 0.7rem;
    color: var(--color-muted);
  }

  :global(.rc-next-badge) {
    margin-top: 0.65rem;
    padding-top: 0.65rem;
    border-top: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .no-data {
    color: var(--color-muted);
    font-size: 0.85rem;
    padding: 1rem;
  }

  @media (max-width: 1024px) {
    #recentResults { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .hub-grid { grid-template-columns: 1fr; }
    #recentResults { grid-template-columns: repeat(2, 1fr); }
  }
</style>
