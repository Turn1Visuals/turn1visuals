---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="F1 Drivers" description="Current F1 driver standings and driver profiles.">

  <div class="page-header">
    <div class="container">
      <p class="section-label">Formula 1</p>
      <h1 class="page-title">Drivers</h1>
    </div>
  </div>

  <div class="container drivers-body">

    <nav class="sub-nav">
      <a href="/f1" class="sub-nav-link">Overview</a>
      <a href="/f1/drivers" class="sub-nav-link sub-nav-link--active">Drivers</a>
      <a href="/f1/teams" class="sub-nav-link">Teams</a>
      <a href="/f1/results" class="sub-nav-link">Results</a>
    </nav>

    <!-- Driver Standings -->
    <section class="section">
      <p class="section-label" style="margin-bottom:1rem">Championship Standings</p>
      <div class="standings-table" id="driverStandings">
        {Array.from({length: 20}).map((_, i) => (
          <div class="standings-row skeleton-row">
            <div class="skeleton sk-pos"></div>
            <div class="skeleton sk-name"></div>
            <div class="skeleton sk-team"></div>
            <div class="skeleton sk-pts"></div>
            <div class="skeleton sk-wins"></div>
          </div>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>

<script>
  async function loadDrivers() {
    const BASE = 'https://api.jolpi.ca/ergast/f1';

    const res = await fetch(`${BASE}/current/driverStandings.json?limit=30`).catch(() => null);
    const el = document.getElementById('driverStandings');
    if (!el) return;

    if (!res || !res.ok) {
      el.innerHTML = '<p class="no-data">Could not load driver standings. Try refreshing.</p>';
      return;
    }

    const data = await res.json();
    const standings = data.MRData?.StandingsTable?.StandingsLists?.[0]?.DriverStandings ?? [];

    if (standings.length === 0) {
      el.innerHTML = '<p class="no-data">Season standings not available yet.</p>';
      return;
    }

    el.innerHTML = `
      <div class="table-header">
        <span class="th-pos">Pos</span>
        <span class="th-driver">Driver</span>
        <span class="th-team">Team</span>
        <span class="th-pts">Points</span>
        <span class="th-wins">Wins</span>
      </div>
      ${standings.map((s: any, idx: number) => `
        <div class="standings-row${idx === 0 ? ' row-leader' : ''}">
          <span class="td-pos">${s.position}</span>
          <div class="td-driver">
            <span class="driver-number">${s.Driver.permanentNumber ?? '—'}</span>
            <div>
              <span class="driver-name">${s.Driver.givenName} ${s.Driver.familyName}</span>
              <span class="driver-nat">${s.Driver.nationality}</span>
            </div>
          </div>
          <span class="td-team">${s.Constructors[0]?.name ?? '—'}</span>
          <span class="td-pts">${s.points}</span>
          <span class="td-wins">${s.wins}</span>
        </div>
      `).join('')}
    `;
  }

  loadDrivers();
</script>

<style>
  .page-header {
    padding-block: 4rem 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    text-transform: uppercase;
    line-height: 1;
    margin-top: 0.5rem;
  }

  .drivers-body { padding-block: 2.5rem 5rem; }

  .sub-nav {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .sub-nav-link {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 0.75rem 1.25rem;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .sub-nav-link:hover { color: var(--color-text); }
  .sub-nav-link--active { color: var(--color-text); border-bottom-color: var(--color-accent); }

  .section { margin-bottom: 4rem; }

  /* Table */
  .standings-table { display: flex; flex-direction: column; gap: 2px; }

  .table-header {
    display: grid;
    grid-template-columns: 3rem 1fr 1fr 6rem 5rem;
    gap: 0;
    padding: 0.5rem 1rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .standings-row {
    display: grid;
    grid-template-columns: 3rem 1fr 1fr 6rem 5rem;
    align-items: center;
    gap: 0;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: border-color 0.15s;
  }

  .standings-row:hover { border-color: var(--color-muted); }
  .row-leader { border-left: 3px solid var(--color-accent); }

  .td-pos {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-muted);
  }

  .td-driver {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .driver-number {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-accent);
    min-width: 2rem;
    line-height: 1;
  }

  .driver-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    line-height: 1.2;
  }

  .driver-nat {
    font-size: 0.72rem;
    color: var(--color-muted);
    display: block;
  }

  .td-team {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .td-pts {
    font-family: 'Inter', monospace;
    font-weight: 600;
    font-size: 1rem;
    text-align: right;
  }

  .td-wins {
    font-family: 'Inter', monospace;
    font-size: 0.9rem;
    color: var(--color-muted);
    text-align: right;
  }

  /* Skeleton */
  .skeleton-row {
    display: grid;
    grid-template-columns: 3rem 1fr 1fr 6rem 5rem;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    align-items: center;
  }

  .sk-pos   { width: 1.5rem; height: 1.4rem; }
  .sk-name  { height: 1.4rem; }
  .sk-team  { height: 1rem; }
  .sk-pts   { height: 1.4rem; }
  .sk-wins  { height: 1rem; }

  .no-data { color: var(--color-muted); font-size: 0.85rem; padding: 1.5rem; }

  @media (max-width: 640px) {
    .table-header { display: none; }
    .standings-row, .skeleton-row {
      grid-template-columns: 2.5rem 1fr 5rem;
    }
    .td-team, .td-wins, .sk-team, .sk-wins { display: none; }
  }
</style>
