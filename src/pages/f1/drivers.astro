---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="F1 Drivers" description="Current F1 driver standings.">

  <div class="page-header">
    <div class="container">
      <p class="section-label">Formula 1</p>
      <h1 class="page-title">Drivers</h1>
    </div>
  </div>

  <div class="container drivers-body">

    <nav class="sub-nav">
      <a href="/f1" class="sub-nav-link">Overview</a>
      <a href="/f1/drivers" class="sub-nav-link sub-nav-link--active">Drivers</a>
      <a href="/f1/teams" class="sub-nav-link">Teams</a>
      <a href="/f1/results" class="sub-nav-link">Results</a>
    </nav>

    <section class="section">
      <p class="section-label" style="margin-bottom:1rem">Championship Standings</p>
      <div class="standings-table" id="driverStandings">
        {Array.from({length: 20}).map(() => (
          <div class="standings-row skeleton-row">
            <div class="skeleton sk-pos"></div>
            <div class="skeleton sk-avatar"></div>
            <div class="skeleton sk-name"></div>
            <div class="skeleton sk-team"></div>
            <div class="skeleton sk-pts"></div>
          </div>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>

<script>
  const OPENF1 = 'https://api.openf1.org/v1';

  async function get<T>(url: string): Promise<T | null> {
    try {
      const res = await fetch(url);
      return res.ok ? await res.json() : null;
    } catch { return null; }
  }

  async function loadDrivers() {
    const el = document.getElementById('driverStandings');
    if (!el) return;

    const [standings, drivers] = await Promise.all([
      get<any[]>(`${OPENF1}/championship_drivers?session_key=latest`),
      get<any[]>(`${OPENF1}/drivers?session_key=latest`),
    ]);

    if (!standings || !drivers) {
      el.innerHTML = '<p class="no-data">Could not load driver standings.</p>';
      return;
    }

    // Build driver info map by driver_number
    const driverMap: Record<number, any> = {};
    for (const d of drivers) driverMap[d.driver_number] = d;

    // Sort by position
    const sorted = standings
      .filter((s: any) => s.position_current)
      .sort((a: any, b: any) => a.position_current - b.position_current);

    if (sorted.length === 0) {
      el.innerHTML = '<p class="no-data">Season standings not available yet.</p>';
      return;
    }

    el.innerHTML = `
      <div class="table-header">
        <span>Pos</span>
        <span class="th-driver">Driver</span>
        <span>Team</span>
        <span>Pts</span>
      </div>
      ${sorted.map((s: any) => {
        const d = driverMap[s.driver_number];
        const color  = d?.team_colour ? `#${d.team_colour}` : 'var(--color-border)';
        const name   = d ? `${d.first_name} ${d.last_name}` : `#${s.driver_number}`;
        const code   = d?.name_acronym ?? '';
        const team   = d?.team_name ?? '—';
        const img    = d?.headshot_url ?? '';
        const isFirst = s.position_current === 1;

        return `
          <div class="standings-row${isFirst ? ' row-leader' : ''}" style="border-left-color:${color}">
            <span class="td-pos">${s.position_current}</span>
            <div class="td-driver">
              ${img ? `<img class="driver-avatar" src="${img}" alt="${name}" loading="lazy">` : '<div class="driver-avatar driver-avatar--empty"></div>'}
              <div>
                <span class="driver-name">${name}</span>
                <span class="driver-code">${code}</span>
              </div>
            </div>
            <span class="td-team">${team}</span>
            <span class="td-pts">${s.points_current}</span>
          </div>
        `;
      }).join('')}
    `;
  }

  loadDrivers();
</script>

<style is:global>
  .page-header {
    padding-block: 4rem 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    text-transform: uppercase;
    line-height: 1;
    margin-top: 0.5rem;
  }

  .drivers-body { padding-block: 2.5rem 5rem; }

  .sub-nav {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .sub-nav-link {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 0.75rem 1.25rem;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .sub-nav-link:hover { color: var(--color-text); }
  .sub-nav-link--active { color: var(--color-text); border-bottom-color: var(--color-accent); }

  .section { margin-bottom: 4rem; }

  .standings-table { display: flex; flex-direction: column; gap: 2px; }

  .table-header {
    display: grid;
    grid-template-columns: 3rem 1fr 1fr 6rem;
    padding: 0.5rem 1rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .standings-row {
    display: grid;
    grid-template-columns: 3rem 1fr 1fr 6rem;
    align-items: center;
    padding: 0.6rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left-width: 3px;
    transition: filter 0.15s;
  }

  .standings-row:hover { filter: brightness(1.1); }
  .row-leader .td-pos { color: var(--color-accent); }

  .td-pos {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-muted);
  }

  .td-driver {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    overflow: hidden;
  }

  .driver-avatar {
    width: 40px;
    height: 40px;
    object-fit: cover;
    object-position: top center;
    flex-shrink: 0;
    border-radius: 2px;
    background: var(--color-border);
  }

  .driver-avatar--empty {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    background: var(--color-border);
    border-radius: 2px;
  }

  .driver-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .driver-code {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }

  .td-team {
    font-size: 0.85rem;
    color: var(--color-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .td-pts {
    font-family: 'Inter', monospace;
    font-weight: 600;
    font-size: 1rem;
    text-align: right;
  }

  /* Skeleton */
  .skeleton-row {
    display: grid;
    grid-template-columns: 3rem 40px 1fr 1fr 6rem;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    align-items: center;
  }

  .sk-pos    { width: 1.5rem; height: 1.4rem; }
  .sk-avatar { width: 40px; height: 40px; flex-shrink: 0; }
  .sk-name   { height: 1.4rem; }
  .sk-team   { height: 1rem; }
  .sk-pts    { height: 1.4rem; }

  .no-data { color: var(--color-muted); font-size: 0.85rem; padding: 1.5rem; }

  @media (max-width: 640px) {
    .table-header { display: none; }
    .standings-row { grid-template-columns: 3rem 1fr 5rem; }
    .td-team { display: none; }
    .skeleton-row { grid-template-columns: 3rem 40px 1fr 5rem; }
    .sk-team { display: none; }
  }
</style>
