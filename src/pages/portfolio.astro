---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allVisuals = await getCollection('visuals');
const visuals = allVisuals.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Unique categories for filter
const categories = ['all', ...new Set(visuals.map(v => v.data.category))];
// Unique seasons for filter
const seasons = [...new Set(visuals.map(v => v.data.season).filter(Boolean))].sort((a, b) => (b ?? 0) - (a ?? 0));
---

<BaseLayout title="Portfolio" description="F1 session result graphics, standings visuals, and more from Turn1Visuals.">

  <div class="page-header">
    <div class="container">
      <p class="section-label">Work</p>
      <h1 class="page-title">Portfolio</h1>
      <p class="page-desc">F1 session results, standings, and qualifying visuals.</p>
    </div>
  </div>

  <div class="container portfolio-body">

    <!-- Filters -->
    <div class="filters" id="filters">
      <div class="filter-group">
        <span class="filter-label">Category</span>
        <div class="filter-buttons" id="filterCategory">
          {categories.map(cat => (
            <button
              class:list={['filter-btn', { 'filter-btn--active': cat === 'all' }]}
              data-filter-cat={cat}
            >
              {cat === 'all' ? 'All' : cat.replace('-', ' ')}
            </button>
          ))}
        </div>
      </div>
      {seasons.length > 1 && (
        <div class="filter-group">
          <span class="filter-label">Season</span>
          <div class="filter-buttons" id="filterSeason">
            <button class="filter-btn filter-btn--active" data-filter-season="all">All</button>
            {seasons.map(s => (
              <button class="filter-btn" data-filter-season={String(s)}>{s}</button>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Grid -->
    {visuals.length > 0 ? (
      <div class="portfolio-grid" id="portfolioGrid">
        {visuals.map(v => (
          <article
            class="visual-card"
            data-cat={v.data.category}
            data-season={String(v.data.season ?? '')}
          >
            <div class="visual-image-wrap">
              <img
                src={`/images/visuals/${v.data.image}`}
                alt={v.data.title}
                class="visual-image"
                loading="lazy"
              />
              <div class="visual-overlay">
                <span class="visual-overlay-text">{v.data.title}</span>
              </div>
            </div>
            <div class="visual-meta">
              <span class="visual-category">{v.data.category.replace('-', ' ')}</span>
              <h2 class="visual-title">{v.data.title}</h2>
              <div class="visual-footer">
                {v.data.race && <span class="visual-race">{v.data.race}</span>}
                {v.data.season && <span class="visual-season">{v.data.season}</span>}
              </div>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-portfolio">
        <p class="empty-title">Visuals coming soon.</p>
        <p class="empty-sub">Follow on social media for the latest F1 graphics.</p>
      </div>
    )}

  </div>
</BaseLayout>

<script>
  // Simple client-side filter — no framework needed
  const grid = document.getElementById('portfolioGrid');
  const cards = grid ? Array.from(grid.querySelectorAll<HTMLElement>('.visual-card')) : [];

  let activeCat = 'all';
  let activeSeason = 'all';

  function applyFilters() {
    cards.forEach(card => {
      const matchCat    = activeCat    === 'all' || card.dataset.cat    === activeCat;
      const matchSeason = activeSeason === 'all' || card.dataset.season === activeSeason;
      card.style.display = matchCat && matchSeason ? '' : 'none';
    });
  }

  document.getElementById('filterCategory')?.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter-cat]');
    if (!btn) return;
    activeCat = btn.dataset.filterCat ?? 'all';
    document.querySelectorAll('[data-filter-cat]').forEach(b => b.classList.remove('filter-btn--active'));
    btn.classList.add('filter-btn--active');
    applyFilters();
  });

  document.getElementById('filterSeason')?.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter-season]');
    if (!btn) return;
    activeSeason = btn.dataset.filterSeason ?? 'all';
    document.querySelectorAll('[data-filter-season]').forEach(b => b.classList.remove('filter-btn--active'));
    btn.classList.add('filter-btn--active');
    applyFilters();
  });
</script>

<style>
  .page-header {
    padding-block: 4rem 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    text-transform: uppercase;
    line-height: 1;
    margin-block: 0.5rem;
  }

  .page-desc {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .portfolio-body {
    padding-block: 3rem 5rem;
  }

  /* Filters */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .filter-buttons {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.35rem 0.85rem;
    background: var(--color-surface);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .filter-btn:hover { color: var(--color-text); border-color: var(--color-muted); }
  .filter-btn--active { color: var(--color-text); border-color: var(--color-accent); }

  /* Grid */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .visual-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .visual-card:hover { border-color: var(--color-muted); }

  .visual-image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-border);
  }

  .visual-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .visual-card:hover .visual-image { transform: scale(1.03); }

  .visual-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.2s;
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
  }

  .visual-card:hover .visual-overlay { opacity: 1; }

  .visual-overlay-text {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .visual-meta {
    padding: 0.875rem 1rem;
  }

  .visual-category {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .visual-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin-top: 0.2rem;
    line-height: 1.3;
  }

  .visual-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.4rem;
  }

  .visual-race {
    font-size: 0.78rem;
    color: var(--color-muted);
  }

  .visual-season {
    font-size: 0.75rem;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-border);
    background: var(--color-border);
    color: var(--color-muted);
    padding: 0.1rem 0.4rem;
  }

  /* Empty */
  .empty-portfolio {
    text-align: center;
    padding-block: 5rem;
  }

  .empty-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .empty-sub { color: var(--color-muted); }

  @media (max-width: 900px) { .portfolio-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .portfolio-grid { grid-template-columns: 1fr; } }
</style>
