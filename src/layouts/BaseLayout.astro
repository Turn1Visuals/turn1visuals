---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'F1 Visuals. Race Data. All in one place.',
} = Astro.props;

const fullTitle = title === 'Home' ? 'Turn1Visuals' : `${title} | Turn1Visuals`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo/icon_white-red.svg" />

    <!-- Fonts loaded via @font-face in global.css (Gotham, self-hosted) -->

    <title>{fullTitle}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
