---
import { Icon } from 'astro-icon/components';

const socials = [
  { name: 'Twitter / X',  href: 'https://twitter.com/Turn1Visuals',   icon: 'simple-icons:x' },
  { name: 'Instagram',    href: 'https://instagram.com/Turn1Visuals',  icon: 'simple-icons:instagram' },
  { name: 'Facebook',     href: 'https://facebook.com/Turn1Visuals',   icon: 'simple-icons:facebook' },
  { name: 'Threads',      href: 'https://threads.net/@Turn1Visuals',   icon: 'simple-icons:threads' },
  { name: 'Mastodon',     href: 'https://mastodon.social/@Turn1Visuals',icon: 'simple-icons:mastodon' },
  { name: 'Bluesky',      href: 'https://bsky.app/profile/turn1visuals.com',icon: 'simple-icons:bluesky' },
  { name: 'Twitch',       href: 'https://twitch.tv/Turn1Visuals',      icon: 'simple-icons:twitch' },
  { name: 'YouTube',      href: 'https://youtube.com/@Turn1Visuals',     icon: 'simple-icons:youtube' },
  { name: 'TikTok',       href: 'https://tiktok.com/@Turn1Visuals',      icon: 'simple-icons:tiktok' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <img src="/logo/icon_white-red.svg" alt="Turn1Visuals" class="footer-logo" />
      <p class="footer-tagline">F1 Visuals. Race Data. All in one place.</p>
    </div>

    <div class="footer-socials">
      <p class="section-label">Find me on</p>
      <div class="social-links">
        {socials.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label={s.name}
            title={s.name}
          >
            <Icon name={s.icon} class="social-icon" />
          </a>
        ))}
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-inner">
        <p class="footer-copy">
          &copy; {year} Turn1Visuals. Not affiliated with Formula 1, FOM, or FIA.
        </p>
        <div class="footer-links">
          <a href="/f1-2026-assets" class="footer-privacy">F1 2026 Assets</a>
          <a href="/privacy" class="footer-privacy">Privacy Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-section);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3rem;
    padding-top: 3rem;
    padding-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  /* Brand */
  .footer-logo {
    display: block;
    height: 40px;
    width: auto;
    margin-bottom: 0.75rem;
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--color-muted);
    max-width: 22ch;
  }

  /* Socials */
  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    transition: color 0.15s, border-color 0.15s;
  }

  .social-link:hover {
    color: var(--color-text);
    border-color: var(--color-muted);
  }

  .social-icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-block: 1rem;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .footer-privacy {
    font-size: 0.8rem;
    color: var(--color-muted);
    transition: color 0.15s;
  }

  .footer-privacy:hover {
    color: var(--color-text);
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: 2rem;
    }
  }
</style>
